---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Clock" description="SVG analog clock with timezone support">
  <main class="min-h-screen flex flex-col items-center justify-center gap-8 px-4">
    <nav class="absolute top-4 left-4">
      <a href={`${base}/`} class="text-zinc-400 hover:text-zinc-100 text-sm transition-colors">← Back</a>
    </nav>

    <!-- Clock SVG -->
    <svg id="clock" viewBox="-110 -110 220 220" class="w-64 h-64 sm:w-80 sm:h-80">
      <circle cx="0" cy="0" r="100" class="clock-face" fill="none" stroke-width="2" />

      {Array.from({ length: 12 }, (_, i) => {
        const angle = (i * 30 - 90) * (Math.PI / 180);
        const x1 = Math.cos(angle) * 88;
        const y1 = Math.sin(angle) * 88;
        const x2 = Math.cos(angle) * 95;
        const y2 = Math.sin(angle) * 95;
        return <line x1={x1} y1={y1} x2={x2} y2={y2} class="clock-tick" stroke-width="2" stroke-linecap="round" />;
      })}

      {Array.from({ length: 60 }, (_, i) => {
        if (i % 5 === 0) return null;
        const angle = (i * 6 - 90) * (Math.PI / 180);
        const x1 = Math.cos(angle) * 91;
        const y1 = Math.sin(angle) * 91;
        const x2 = Math.cos(angle) * 95;
        const y2 = Math.sin(angle) * 95;
        return <line x1={x1} y1={y1} x2={x2} y2={y2} class="clock-tick-minor" stroke-width="1" stroke-linecap="round" />;
      })}

      <line id="hand-hour"   x1="0" y1="0"  x2="0" y2="-55" class="clock-hand-hour"   stroke-width="4"   stroke-linecap="round" />
      <line id="hand-minute" x1="0" y1="0"  x2="0" y2="-75" class="clock-hand-minute" stroke-width="2.5" stroke-linecap="round" />
      <line id="hand-second" x1="0" y1="12" x2="0" y2="-82" class="clock-hand-second" stroke-width="1.5" stroke-linecap="round" />

      <circle cx="0" cy="0" r="4" class="clock-center" />
      <circle cx="0" cy="0" r="2" class="clock-center-dot" />
    </svg>

    <!-- デジタル時刻 -->
    <div class="text-center">
      <p id="digital" class="text-3xl font-mono tabular-nums" style="color: var(--c-hand)"></p>
      <p id="date-label" class="text-sm mt-1" style="color: var(--c-tick)"></p>
    </div>

    <!-- タイムゾーン選択 -->
    <div class="flex flex-wrap justify-center gap-2">
      {[
        { label: 'Tokyo',       tz: 'Asia/Tokyo' },
        { label: 'London',      tz: 'Europe/London' },
        { label: 'New York',    tz: 'America/New_York' },
        { label: 'Los Angeles', tz: 'America/Los_Angeles' },
      ].map(({ label, tz }) => (
        <button
          data-tz={tz}
          class="tz-btn px-3 py-1.5 rounded-full text-sm border border-zinc-700 text-zinc-400 hover:border-zinc-400 hover:text-zinc-100 transition-colors"
        >
          {label}
        </button>
      ))}
    </div>

    <!-- テーマ選択 -->
    <div class="flex flex-wrap justify-center gap-2">
      {[
        { label: 'Dark',    id: 'dark' },
        { label: 'Light',   id: 'light' },
        { label: 'Neon',    id: 'neon' },
        { label: 'Warm',    id: 'warm' },
        { label: 'Mono',    id: 'mono' },
      ].map(({ label, id }) => (
        <button
          data-theme={id}
          class="theme-btn px-3 py-1.5 rounded-full text-sm border border-zinc-700 text-zinc-400 hover:border-zinc-400 hover:text-zinc-100 transition-colors"
        >
          {label}
        </button>
      ))}
    </div>
  </main>
</Layout>

<style>
  /* --- テーマ CSS 変数 --- */
  :root {
    --c-face:   #3f3f46;
    --c-tick:   #71717a;
    --c-tick-m: #3f3f46;
    --c-hand:   #e4e4e7;
    --c-second: #f97316;
    --c-center: #e4e4e7;
    --c-dot:    #09090b;
    --c-bg:     #09090b;
  }

  [data-theme="light"] {
    --c-face:   #d4d4d8;
    --c-tick:   #52525b;
    --c-tick-m: #d4d4d8;
    --c-hand:   #18181b;
    --c-second: #ea580c;
    --c-center: #18181b;
    --c-dot:    #ffffff;
    --c-bg:     #f4f4f5;
  }

  [data-theme="neon"] {
    --c-face:   #0e4429;
    --c-tick:   #00ff88;
    --c-tick-m: #006633;
    --c-hand:   #00ffcc;
    --c-second: #ff00ff;
    --c-center: #00ffcc;
    --c-dot:    #000000;
    --c-bg:     #020d0a;
  }

  [data-theme="warm"] {
    --c-face:   #78350f;
    --c-tick:   #fbbf24;
    --c-tick-m: #92400e;
    --c-hand:   #fef3c7;
    --c-second: #f87171;
    --c-center: #fef3c7;
    --c-dot:    #1c0a00;
    --c-bg:     #1c0a00;
  }

  [data-theme="mono"] {
    --c-face:   #555555;
    --c-tick:   #aaaaaa;
    --c-tick-m: #444444;
    --c-hand:   #ffffff;
    --c-second: #ffffff;
    --c-center: #ffffff;
    --c-dot:    #000000;
    --c-bg:     #111111;
  }

  /* --- SVG への適用 --- */
  main        { background-color: var(--c-bg); transition: background-color 0.3s; }
  .clock-face       { stroke: var(--c-face); }
  .clock-tick       { stroke: var(--c-tick); }
  .clock-tick-minor { stroke: var(--c-tick-m); }
  .clock-hand-hour, .clock-hand-minute { stroke: var(--c-hand); }
  .clock-hand-second { stroke: var(--c-second); }
  .clock-center      { fill: var(--c-center); }
  .clock-center-dot  { fill: var(--c-dot); }
</style>

<script>
  let timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;

  const handHour   = document.getElementById('hand-hour')!;
  const handMinute = document.getElementById('hand-minute')!;
  const handSecond = document.getElementById('hand-second')!;
  const digital    = document.getElementById('digital')!;
  const dateLabel  = document.getElementById('date-label')!;
  const main       = document.querySelector('main')!;

  function getTimeInZone(tz: string) {
    const now = new Date();
    const parts = new Intl.DateTimeFormat('en-US', {
      timeZone: tz,
      hour: 'numeric', minute: 'numeric', second: 'numeric',
      hour12: false,
    }).formatToParts(now);

    const get = (type: string) => parseInt(parts.find(p => p.type === type)?.value ?? '0');
    return { h: get('hour') % 12, m: get('minute'), s: get('second') };
  }

  function formatDigital(tz: string) {
    return new Intl.DateTimeFormat('ja-JP', {
      timeZone: tz,
      hour: '2-digit', minute: '2-digit', second: '2-digit',
      hour12: false,
    }).format(new Date());
  }

  function formatDate(tz: string) {
    return new Intl.DateTimeFormat('ja-JP', {
      timeZone: tz,
      year: 'numeric', month: 'long', day: 'numeric', weekday: 'short',
    }).format(new Date());
  }

  function setRotation(el: HTMLElement, deg: number) {
    el.setAttribute('transform', `rotate(${deg})`);
  }

  function tick() {
    const { h, m, s } = getTimeInZone(timezone);
    setRotation(handSecond as HTMLElement, s * 6);
    setRotation(handMinute as HTMLElement, m * 6 + s * 0.1);
    setRotation(handHour   as HTMLElement, h * 30 + m * 0.5);
    digital.textContent   = formatDigital(timezone);
    dateLabel.textContent = formatDate(timezone);
  }

  // タイムゾーンボタン
  document.querySelectorAll<HTMLButtonElement>('.tz-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      timezone = btn.dataset.tz!;
      document.querySelectorAll('.tz-btn').forEach(b =>
        b.classList.remove('border-zinc-100', 'text-zinc-100')
      );
      btn.classList.add('border-zinc-100', 'text-zinc-100');
      tick();
    });
  });

  // テーマボタン
  document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      main.dataset.theme = btn.dataset.theme!;
      document.querySelectorAll('.theme-btn').forEach(b =>
        b.classList.remove('border-zinc-100', 'text-zinc-100')
      );
      btn.classList.add('border-zinc-100', 'text-zinc-100');
    });
  });

  tick();
  setInterval(tick, 1000);
</script>
