---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Clock" description="SVG analog clock with timezone support">
  <main class="min-h-screen flex flex-col items-center justify-center gap-8">
    <nav class="absolute top-4 left-4">
      <a href="/" class="text-zinc-400 hover:text-zinc-100 text-sm transition-colors">← Back</a>
    </nav>

    <svg id="clock" viewBox="-110 -110 220 220" class="w-64 h-64">
      <!-- TODO: アナログ時計 SVG 実装 -->
      <circle cx="0" cy="0" r="100" fill="none" stroke="#3f3f46" stroke-width="2" />
      <text x="0" y="5" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="monospace">coming soon</text>
    </svg>
  </main>
</Layout>
