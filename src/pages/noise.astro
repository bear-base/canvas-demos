---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Noise Art" description="Perlin noise generative art">
  <main class="min-h-screen flex flex-col">
    <nav class="p-4">
      <a href="/" class="text-zinc-400 hover:text-zinc-100 text-sm transition-colors">← Back</a>
    </nav>
    <div class="flex-1 relative">
      <canvas id="canvas" class="w-full h-full block" />
    </div>
  </main>
</Layout>

<script>
  // TODO: Perlin noise 実装
  const canvas = document.getElementById('canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function resize() {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }
  window.addEventListener('resize', resize);
  resize();

  ctx.fillStyle = '#09090b';
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.fillStyle = '#a1a1aa';
  ctx.font = '14px monospace';
  ctx.textAlign = 'center';
  ctx.fillText('Noise — coming soon', canvas.width / 2, canvas.height / 2);
</script>
